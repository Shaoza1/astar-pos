DATABASE_URL=postgresql://user:password@localhost:5432/astar_pos
JWT_SECRET=change-me-in-production
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Rate limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Database connection pool
DB_POOL_MAX=10
DB_POOL_MIN=2

# Logging
LOG_LEVEL=info

# Card payment providers — use sandbox keys for development
YOCO_SECRET_KEY=sk_test_your_key_here
YOCO_ENV=sandbox
PEACH_ACCESS_TOKEN=your_token_here
PEACH_ENTITY_ID=your_entity_id_here
PEACH_ENV=sandbox
PAYMENT_PROVIDER=yoco
